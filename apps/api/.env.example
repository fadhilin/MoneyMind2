# Environment Variables for FinanceControl API

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/financecontrol"

# Better Auth
BETTER_AUTH_SECRET="change-this-to-a-long-random-secret-string"
BETTER_AUTH_URL="http://localhost:3001"

# CORS — frontend origin
FRONTEND_URL="http://localhost:5173"

# Server
PORT=3001
